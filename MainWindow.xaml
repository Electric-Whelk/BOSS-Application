<Window x:Class="BOSS_Application.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BOSS_Application"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <ResourceDictionary Source="Templates/AItem.xaml"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>

        <!--Top Bar-->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <ProgressBar Grid.Column="0" Minimum="0" Maximum="{Binding BarLength}" Foreground="{Binding Strobe}" Value="{Binding Timer.InSeconds}" />
            <Button Grid.Column="1" Content="Results" Command="{Binding Output}"/>
            <Button Grid.Column="2" Content="Start" Command="{Binding TimerClick}"/>
        </Grid>

        <!--Main Content-->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding CBs}"
                     ItemTemplate="{StaticResource CBTemplate}"/>
            <ListBox Grid.Column="1"
                     x:Name="OBList"
                     ItemsSource="{Binding OBs}"
                     ItemTemplate="{StaticResource OBTemplate}"/>
        </Grid>
        
        <!-- Lower Info Panel -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{Binding Timer.Elapsed}"/>
            <TextBlock Grid.Column="1" Text="{Binding Timer.CountDown}"/>
            <TextBlock Grid.Column="2" Text="{Binding Timer.InSeconds}"/>


        </Grid>
    </Grid>
</Window>
